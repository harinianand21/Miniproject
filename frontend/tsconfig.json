{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "lib": [
            "ESNext",
            "DOM",
            "DOM.Iterable"
        ],
        "useDefineForClassFields": true,
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "strict": false,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noFallthroughCasesInSwitch": false,
        "noImplicitAny": false,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        "types": [
            "node",
            "react",
            "react-dom",
            "leaflet",
            "three",
            "webxr"
        ]
    },
    "include": [
        "src",
        "vite.config.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}